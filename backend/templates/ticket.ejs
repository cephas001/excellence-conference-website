<div
  style="
    font-family: &quot;Segoe UI&quot;, Tahoma, Geneva, Verdana, sans-serif;
    max-width: 600px;
    margin: 0 auto;
    background-color: #f8fafc;
    padding: 40px 20px;
  "
>
  <div
    style="
      background-color: #ffffff;
      border-radius: 16px;
      overflow: hidden;
      box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
      max-width: 600px;
      margin: 0 auto;
      border: 1px solid #e2e8f0;
    "
  >
    <div
      style="background-color: #000000; padding: 35px 20px; text-align: center"
    >
      <h1
        style="
          color: #ffffff;
          margin: 0;
          font-size: 26px;
          letter-spacing: 1.5px;
          text-transform: uppercase;
        "
      >
        Excellence Conference
      </h1>
      <p
        style="
          color: #94a3b8;
          margin: 8px 0 0 0;
          font-size: 14px;
          letter-spacing: 0.5px;
        "
      >
        Workers Dinner & Awards Night
      </p>
    </div>

    <div style="padding: 40px 30px">
      <h2 style="color: #0f172a; font-size: 22px; margin-top: 0">
        Hello <%= applicantName %>,
      </h2>

      <p style="color: #475569; font-size: 16px; line-height: 1.6">
        Your registration for the Excellence Conference Workers Dinner has been
        <strong>successfully verified!</strong>
      </p>

      <p style="color: #475569; font-size: 16px; line-height: 1.6">
        Please present the official ticket below at the venue entrance for
        scanning and seating verification.
      </p>

      <div style="text-align: center; margin: 35px 0 15px 0">
        <img
          src="cid:customizedTicket.png"
          alt="Your Customized Dinner Ticket"
          style="
            max-width: 100%;
            border-radius: 12px;
            box-shadow:
              0 4px 6px -1px rgba(0, 0, 0, 0.1),
              0 2px 4px -1px rgba(0, 0, 0, 0.06);
            display: block;
            margin: 0 auto;
          "
        />
      </div>

      <div
        style="
          background-color: #f0fdf4;
          border: 1px solid #bbf7d0;
          border-radius: 8px;
          padding: 12px 16px;
          text-align: center;
          margin-bottom: 35px;
        "
      >
        <p style="margin: 0; color: #166534; font-size: 13px; font-weight: 500">
          💡 Tip: You can download this ticket using the attachment at the very
          bottom of this email.
        </p>
      </div>

      <div
        style="
          background-color: #f8fafc;
          border-left: 4px solid #000000;
          padding: 16px 20px;
          border-radius: 0 8px 8px 0;
        "
      >
        <p style="margin: 0; color: #64748b; font-size: 14px">
          Assigned Seating:
        </p>
        <p
          style="
            margin: 4px 0 0 0;
            color: #0f172a;
            font-size: 18px;
            font-weight: bold;
          "
        >
          <%= tableChoice %>
        </p>
      </div>
    </div>

    <div
      style="
        background-color: #f8fafc;
        padding: 25px;
        text-align: center;
        border-top: 1px solid #f1f5f9;
      "
    >
      <p style="color: #94a3b8; font-size: 13px; margin: 0; line-height: 1.5">
        Dress Elegantly.<br />
        If you have any questions, please reply directly to this email.
      </p>
    </div>
  </div>
</div>
